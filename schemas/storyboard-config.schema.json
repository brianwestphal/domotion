{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/brianwestphal/domotion/main/schemas/storyboard-config.schema.json",
  "title": "Domotion storyboard config",
  "description": "Config for the `domotion storyboard` CLI: an ordered list of scenes (each a template / capture / cast / svg source), each with a duration and an inter-scene transition, sequenced into one animated SVG. See docs/89-storyboard-sequencing.md. Authoritative validation is the zod schema in src/cli/storyboard.ts; the exactly-one-source-per-scene rule is enforced at runtime and not expressed here.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional pointer to this JSON Schema for editor support; ignored by the CLI."
    },
    "width": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "height": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "output": {
      "type": "string"
    },
    "background": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "desc": {
      "type": "string"
    },
    "cursor": {
      "type": "object",
      "properties": {
        "style": {
          "type": "object",
          "properties": {
            "scale": {
              "type": "number"
            },
            "color": {
              "type": "string"
            },
            "pulseColor": {
              "type": "string"
            },
            "pulseRadius": {
              "type": "number"
            },
            "pulseDurationMs": {
              "type": "number"
            }
          }
        },
        "events": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "frame": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "at": {
                "default": 0,
                "type": "number"
              },
              "type": {
                "type": "string",
                "enum": [
                  "move",
                  "click",
                  "moveClick",
                  "hide"
                ]
              },
              "selector": {
                "type": "string"
              },
              "to": {
                "type": "object",
                "properties": {
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  }
                },
                "required": [
                  "x",
                  "y"
                ]
              },
              "offset": {
                "type": "object",
                "properties": {
                  "dx": {
                    "type": "number"
                  },
                  "dy": {
                    "type": "number"
                  }
                },
                "required": [
                  "dx",
                  "dy"
                ]
              },
              "duration": {
                "type": "number"
              },
              "button": {
                "type": "string",
                "enum": [
                  "primary",
                  "secondary",
                  "middle"
                ]
              }
            },
            "required": [
              "frame",
              "type"
            ]
          }
        }
      },
      "required": [
        "events"
      ]
    },
    "scenes": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "template": {
            "description": "A template name to render as this scene.",
            "type": "string"
          },
          "params": {
            "description": "Params for a `template` scene.",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "capture": {
            "description": "Capture a live url/file as this scene.",
            "type": "object",
            "properties": {
              "url": {
                "description": "A URL to capture (http/https).",
                "type": "string"
              },
              "file": {
                "description": "A local HTML file path to capture (relative to the config).",
                "type": "string"
              },
              "selector": {
                "description": "Element selector to capture (default: body).",
                "type": "string"
              },
              "wait": {
                "description": "Settle time (ms) after load (default 200).",
                "type": "number",
                "minimum": 0
              },
              "waitFor": {
                "description": "Wait for this selector to be visible before capture.",
                "type": "string"
              },
              "mobile": {
                "description": "Emulate a mobile device (iOS UA).",
                "type": "boolean"
              },
              "colorScheme": {
                "type": "string",
                "enum": [
                  "light",
                  "dark",
                  "no-preference"
                ]
              }
            }
          },
          "cast": {
            "description": "Path to an asciinema v2 .cast (rendered as an animated terminal scene).",
            "type": "string"
          },
          "term": {
            "description": "Terminal options for a `cast` scene.",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "svg": {
            "description": "Path to a pre-rendered SVG (static or animated) as this scene.",
            "type": "string"
          },
          "period": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "fit": {
            "type": "string",
            "enum": [
              "center",
              "contain",
              "cover"
            ]
          },
          "duration": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "transition": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "crossfade",
                  "cut",
                  "push-left",
                  "scroll",
                  "push-right",
                  "push-up",
                  "push-down",
                  "wipe",
                  "iris",
                  "zoom-in",
                  "zoom-out",
                  "shine"
                ]
              },
              "duration": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "type",
              "duration"
            ]
          },
          "overlays": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "typing"
                    },
                    "text": {
                      "type": "string"
                    },
                    "x": {
                      "default": 0,
                      "type": "number"
                    },
                    "y": {
                      "default": 0,
                      "type": "number"
                    },
                    "fontSize": {
                      "type": "number"
                    },
                    "fontFamily": {
                      "type": "string"
                    },
                    "kern": {
                      "type": "boolean"
                    },
                    "color": {
                      "type": "string"
                    },
                    "delay": {
                      "type": "number"
                    },
                    "speed": {
                      "type": "number"
                    },
                    "mode": {
                      "type": "string",
                      "enum": [
                        "type",
                        "paste"
                      ]
                    },
                    "jitter": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "wrapWidth": {
                      "type": "number"
                    },
                    "mask": {
                      "type": "object",
                      "properties": {
                        "width": {
                          "type": "number"
                        },
                        "height": {
                          "type": "number"
                        },
                        "color": {
                          "type": "string"
                        }
                      }
                    },
                    "bgColor": {
                      "type": "string"
                    },
                    "bgWidth": {
                      "type": "number"
                    },
                    "bgHeight": {
                      "type": "number"
                    },
                    "caret": {
                      "anyOf": [
                        {
                          "type": "boolean"
                        },
                        {
                          "type": "object",
                          "properties": {
                            "color": {
                              "type": "string"
                            },
                            "width": {
                              "type": "number"
                            },
                            "blinkMs": {
                              "type": "number"
                            },
                            "shape": {
                              "type": "string",
                              "enum": [
                                "bar",
                                "block",
                                "underscore"
                              ]
                            }
                          }
                        }
                      ]
                    },
                    "mistakes": {
                      "anyOf": [
                        {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1
                        },
                        {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "at": {
                                "type": "integer",
                                "minimum": 0,
                                "maximum": 9007199254740991
                              },
                              "wrong": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "at"
                            ]
                          }
                        }
                      ]
                    },
                    "mistakeThinkMs": {
                      "type": "number"
                    },
                    "holdToFrameEnd": {
                      "type": "boolean"
                    },
                    "anchor": {
                      "type": "object",
                      "properties": {
                        "selector": {
                          "type": "string"
                        },
                        "at": {
                          "type": "string",
                          "enum": [
                            "top-left",
                            "top",
                            "top-right",
                            "left",
                            "center",
                            "right",
                            "bottom-left",
                            "bottom",
                            "bottom-right"
                          ]
                        },
                        "dx": {
                          "type": "number"
                        },
                        "dy": {
                          "type": "number"
                        },
                        "baseline": {
                          "type": "boolean"
                        }
                      },
                      "required": [
                        "selector"
                      ],
                      "additionalProperties": false
                    },
                    "maxWidth": {
                      "anyOf": [
                        {
                          "type": "string",
                          "const": "anchor"
                        },
                        {
                          "type": "number"
                        }
                      ]
                    }
                  },
                  "required": [
                    "kind",
                    "text"
                  ]
                },
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "tap"
                    },
                    "x": {
                      "default": 0,
                      "type": "number"
                    },
                    "y": {
                      "default": 0,
                      "type": "number"
                    },
                    "delay": {
                      "type": "number"
                    },
                    "anchor": {
                      "type": "object",
                      "properties": {
                        "selector": {
                          "type": "string"
                        },
                        "at": {
                          "type": "string",
                          "enum": [
                            "top-left",
                            "top",
                            "top-right",
                            "left",
                            "center",
                            "right",
                            "bottom-left",
                            "bottom",
                            "bottom-right"
                          ]
                        },
                        "dx": {
                          "type": "number"
                        },
                        "dy": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "selector"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "svg"
                    },
                    "src": {
                      "type": "string"
                    },
                    "x": {
                      "default": 0,
                      "type": "number"
                    },
                    "y": {
                      "default": 0,
                      "type": "number"
                    },
                    "width": {
                      "type": "number"
                    },
                    "height": {
                      "type": "number"
                    },
                    "enter": {
                      "type": "object",
                      "properties": {
                        "from": {
                          "type": "string",
                          "enum": [
                            "top",
                            "bottom",
                            "left",
                            "right"
                          ]
                        },
                        "duration": {
                          "type": "number"
                        },
                        "easing": {
                          "type": "string"
                        },
                        "delay": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "from",
                        "duration"
                      ]
                    },
                    "exit": {
                      "type": "object",
                      "properties": {
                        "from": {
                          "type": "string",
                          "enum": [
                            "top",
                            "bottom",
                            "left",
                            "right"
                          ]
                        },
                        "duration": {
                          "type": "number"
                        },
                        "easing": {
                          "type": "string"
                        },
                        "delay": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "from",
                        "duration"
                      ]
                    },
                    "anchor": {
                      "type": "object",
                      "properties": {
                        "selector": {
                          "type": "string"
                        },
                        "at": {
                          "type": "string",
                          "enum": [
                            "top-left",
                            "top",
                            "top-right",
                            "left",
                            "center",
                            "right",
                            "bottom-left",
                            "bottom",
                            "bottom-right"
                          ]
                        },
                        "dx": {
                          "type": "number"
                        },
                        "dy": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "selector"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "kind",
                    "src",
                    "width",
                    "height"
                  ]
                },
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "blink"
                    },
                    "x": {
                      "default": 0,
                      "type": "number"
                    },
                    "y": {
                      "default": 0,
                      "type": "number"
                    },
                    "width": {
                      "type": "number"
                    },
                    "height": {
                      "type": "number"
                    },
                    "periodMs": {
                      "type": "number"
                    },
                    "color": {
                      "type": "string"
                    },
                    "fillOpacity": {
                      "type": "number"
                    },
                    "radius": {
                      "type": "number"
                    },
                    "delay": {
                      "type": "number"
                    },
                    "anchor": {
                      "type": "object",
                      "properties": {
                        "selector": {
                          "type": "string"
                        },
                        "at": {
                          "type": "string",
                          "enum": [
                            "top-left",
                            "top",
                            "top-right",
                            "left",
                            "center",
                            "right",
                            "bottom-left",
                            "bottom",
                            "bottom-right"
                          ]
                        },
                        "dx": {
                          "type": "number"
                        },
                        "dy": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "selector"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "kind",
                    "width",
                    "height"
                  ]
                },
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "shine"
                    },
                    "x": {
                      "default": 0,
                      "type": "number"
                    },
                    "y": {
                      "default": 0,
                      "type": "number"
                    },
                    "width": {
                      "default": 0,
                      "type": "number"
                    },
                    "height": {
                      "default": 0,
                      "type": "number"
                    },
                    "delay": {
                      "type": "number"
                    },
                    "duration": {
                      "type": "number"
                    },
                    "color": {
                      "type": "string"
                    },
                    "opacity": {
                      "type": "number"
                    },
                    "bandWidth": {
                      "type": "number"
                    },
                    "skewDeg": {
                      "type": "number"
                    },
                    "radius": {
                      "type": "number"
                    },
                    "repeat": {
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "string",
                          "const": "infinite"
                        }
                      ]
                    },
                    "repeatPeriodMs": {
                      "type": "number"
                    },
                    "anchor": {
                      "type": "object",
                      "properties": {
                        "selector": {
                          "type": "string"
                        },
                        "at": {
                          "type": "string",
                          "enum": [
                            "top-left",
                            "top",
                            "top-right",
                            "left",
                            "center",
                            "right",
                            "bottom-left",
                            "bottom",
                            "bottom-right"
                          ]
                        },
                        "dx": {
                          "type": "number"
                        },
                        "dy": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "selector"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "kind"
                  ]
                },
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "interact"
                    },
                    "x": {
                      "default": 0,
                      "type": "number"
                    },
                    "y": {
                      "default": 0,
                      "type": "number"
                    },
                    "width": {
                      "default": 0,
                      "type": "number"
                    },
                    "height": {
                      "default": 0,
                      "type": "number"
                    },
                    "treatment": {
                      "type": "string",
                      "enum": [
                        "hover",
                        "focus",
                        "press"
                      ]
                    },
                    "fill": {
                      "type": "string"
                    },
                    "fillOpacity": {
                      "type": "number"
                    },
                    "ring": {
                      "type": "string"
                    },
                    "ringWidth": {
                      "type": "number"
                    },
                    "radius": {
                      "type": "number"
                    },
                    "scale": {
                      "type": "number"
                    },
                    "delay": {
                      "type": "number"
                    },
                    "duration": {
                      "type": "number"
                    },
                    "holdMs": {
                      "type": "number"
                    },
                    "releaseMs": {
                      "type": "number"
                    },
                    "repeat": {
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "string",
                          "const": "infinite"
                        }
                      ]
                    },
                    "repeatPeriodMs": {
                      "type": "number"
                    },
                    "anchor": {
                      "type": "object",
                      "properties": {
                        "selector": {
                          "type": "string"
                        },
                        "at": {
                          "type": "string",
                          "enum": [
                            "top-left",
                            "top",
                            "top-right",
                            "left",
                            "center",
                            "right",
                            "bottom-left",
                            "bottom",
                            "bottom-right"
                          ]
                        },
                        "dx": {
                          "type": "number"
                        },
                        "dy": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "selector"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "kind"
                  ]
                }
              ]
            }
          }
        }
      }
    }
  },
  "required": [
    "width",
    "height",
    "scenes"
  ]
}
