tests/output/*
# DM-987: the Windows DirectWrite font-routing sweep is committed (unlike the
# macOS/Linux sweeps, which regenerate locally) because a Windows box is the
# friction point — keeping the JSON in-tree lets contributors re-run
# tools/probe-983-genroutes-win32.mjs without one. (`tests/output/*` still
# ignores every other entry, including subdirectories, wholesale.)
!tests/output/unicode-fonts.win32.json
tests/cache/
examples/output/*.mp4
examples/output/*.webm
# Intermediate capture HTML the example scripts write next to their SVG output —
# scratch artifacts, regenerated on every run (DM-1334).
examples/output/*.html
node_modules/
external/
dist/
.release-state.json
*.map
.DS_Store
coverage/
scheduled_tasks.lock
test-results/
.env
.env.local
data/
*.tsbuildinfo
.tmp/
tools/unicode-fixtures/

# Reusable-but-uncommitted scratch probes/tools (DM-1216 cleanup).
# The underscore-prefixed one-off debug scripts live here so they persist
# locally without cluttering `git status` or risking an accidental commit.
tools/scratch/

.mcp.json
.claude/settings.local.json
/.hotsheet/*
!/.hotsheet/settings.json
/.glassbox/*
!/.glassbox/settings.json