{
  "$schema": "https://raw.githubusercontent.com/brianwestphal/domotion/main/schemas/animate-config.schema.json",
  "width": 560,
  "height": 480,
  "frames": [
    {
      "input": "./signup.html",
      "actions": [{ "type": "focus", "selector": ".f-name" }],
      "duration": 1900,
      "transition": { "type": "cut", "duration": 0 },
      "overlays": [
        { "kind": "typing", "text": "Ada Lovelace", "x": 102, "y": 181, "fontSize": 14, "color": "#e6edf3", "speed": 85, "caret": true }
      ]
    },
    {
      "continue": true,
      "actions": [
        { "type": "fill", "selector": ".f-name", "value": "Ada Lovelace" },
        { "type": "focus", "selector": ".f-email" }
      ],
      "duration": 2200,
      "transition": { "type": "cut", "duration": 0 },
      "overlays": [
        { "kind": "typing", "text": "ada@analytical.dev", "x": 102, "y": 257, "fontSize": 14, "color": "#e6edf3", "speed": 75, "caret": true }
      ]
    },
    {
      "continue": true,
      "actions": [
        { "type": "fill", "selector": ".f-email", "value": "ada@analytical.dev" },
        { "type": "focus", "selector": ".f-pw" }
      ],
      "duration": 1700,
      "transition": { "type": "cut", "duration": 0 },
      "overlays": [
        { "kind": "typing", "text": "•••••••••••", "x": 102, "y": 333, "fontSize": 14, "color": "#e6edf3", "speed": 75, "caret": true }
      ]
    },
    {
      "continue": true,
      "actions": [
        { "type": "fill", "selector": ".f-pw", "value": "sk-9Qx2vLp4" },
        { "type": "click", "selector": ".submit" }
      ],
      "wait": 150,
      "duration": 2400,
      "transition": { "type": "cut", "duration": 0 }
    }
  ]
}
