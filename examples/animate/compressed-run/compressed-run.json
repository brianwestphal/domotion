{
  "$schema": "https://raw.githubusercontent.com/brianwestphal/domotion/main/schemas/animate-config.schema.json",
  "width": 640,
  "height": 360,
  "frames": [
    {
      "input": "./editor.html",
      "duration": 1910,
      "transition": { "type": "cut", "duration": 0 },
      "caret": { "color": "#e2e8f0" },
      "states": [
        { "duration": 260 },
        { "actions": [{ "type": "evaluate", "script": "ins(2)" }], "duration": 150 },
        { "actions": [{ "type": "evaluate", "script": "ins(4)" }], "duration": 150 },
        { "actions": [{ "type": "evaluate", "script": "ins(6)" }], "duration": 150 },
        { "actions": [{ "type": "evaluate", "script": "ins(8)" }], "duration": 150 },
        { "actions": [{ "type": "evaluate", "script": "ins(10)" }], "duration": 150 },
        { "actions": [{ "type": "evaluate", "script": "colorize()" }], "duration": 900 }
      ]
    },
    {
      "continue": true,
      "duration": 2200,
      "transition": { "type": "cut", "duration": 0 },
      "textTracks": [
        {
          "selector": "[data-line='3']",
          "color": "#93c5fd",
          "events": [
            { "type": "park", "at": 200, "charOffset": 24 },
            { "type": "move", "at": 600, "charOffset": 14 },
            { "type": "select", "at": 800, "charStart": 14, "charEnd": 20, "sweepMs": 450 }
          ]
        }
      ]
    }
  ]
}
