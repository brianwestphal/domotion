{
  "$schema": "https://raw.githubusercontent.com/brianwestphal/domotion/main/schemas/animate-config.schema.json",
  "width": 720,
  "height": 405,
  "brand": "./brand.json",
  "frames": [
    {
      "template": "lower-third",
      "params": { "title": "Acme Cloud", "subtitle": "One brand, every frame", "holdMs": 2400 },
