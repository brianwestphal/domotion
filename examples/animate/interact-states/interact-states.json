{
  "$schema": "https://raw.githubusercontent.com/brianwestphal/domotion/main/schemas/animate-config.schema.json",
  "width": 640,
  "height": 220,
  "frames": [
    {
      "input": "./interact-states.html",
      "duration": 3600,
      "transition": { "type": "cut", "duration": 0 },
      "overlays": [
        { "kind": "interact", "treatment": "hover", "x": 69,  "y": 84, "width": 150, "height": 52, "radius": 10, "repeat": "infinite", "repeatPeriodMs": 1800 },
        { "kind": "interact", "treatment": "focus", "x": 245, "y": 84, "width": 150, "height": 52, "radius": 10, "repeat": "infinite", "repeatPeriodMs": 1800 },
        { "kind": "interact", "treatment": "press", "x": 421, "y": 84, "width": 150, "height": 52, "radius": 10, "repeat": "infinite", "repeatPeriodMs": 1800 }
      ]
    }
  ]
}
