{
  "$schema": "https://raw.githubusercontent.com/brianwestphal/domotion/main/schemas/animate-config.schema.json",
  "width": 720,
  "height": 360,
  "frames": [
    {
      "input": "./step-1-clone.html",
      "duration": 4300,
      "transition": { "type": "push-left", "duration": 450 },
      "overlays": [
        { "kind": "typing", "text": "git clone https://github.com/acme/web.git", "x": 105, "y": 170, "fontSize": 13.5, "color": "#cdd6f4", "speed": 60, "caret": true }
      ],
      "animations": [
        { "selector": ".results", "property": "clipPath", "from": "inset(0 0 100% 0)", "to": "inset(0 0 0 0)", "duration": 250, "delay": 2610 }
      ]
    },
    {
      "input": "./step-2-install.html",
      "duration": 2600,
      "transition": { "type": "push-left", "duration": 450 },
      "overlays": [
        { "kind": "typing", "text": "npm install", "x": 105, "y": 170, "fontSize": 13.5, "color": "#cdd6f4", "speed": 60, "caret": true }
      ],
      "animations": [
        { "selector": ".results", "property": "clipPath", "from": "inset(0 0 100% 0)", "to": "inset(0 0 0 0)", "duration": 250, "delay": 810 }
      ]
    },
    {
      "input": "./step-3-configure.html",
      "duration": 2700,
      "transition": { "type": "push-left", "duration": 450 },
      "overlays": [
        { "kind": "typing", "text": "npm run setup", "x": 105, "y": 170, "fontSize": 13.5, "color": "#cdd6f4", "speed": 60, "caret": true }
      ],
      "animations": [
        { "selector": ".results", "property": "clipPath", "from": "inset(0 0 100% 0)", "to": "inset(0 0 0 0)", "duration": 250, "delay": 930 }
      ]
    },
    {
      "input": "./step-4-run.html",
      "duration": 3000,
      "transition": { "type": "push-left", "duration": 450 },
      "overlays": [
        { "kind": "typing", "text": "npm run dev", "x": 105, "y": 170, "fontSize": 13.5, "color": "#cdd6f4", "speed": 60, "caret": true }
      ],
      "animations": [
        { "selector": ".results", "property": "clipPath", "from": "inset(0 0 100% 0)", "to": "inset(0 0 0 0)", "duration": 250, "delay": 810 }
      ]
    }
  ]
}
