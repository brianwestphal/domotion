{
  "name": "domotion-svg",
  "version": "0.4.2",
  "description": "DOM-to-animated-SVG renderer. Captures HTML/CSS via Playwright Chromium and converts it to self-contained SVG with CSS animations — pixel-faithful demos that scale crisply and load lazily.",
  "license": "MIT",
  "author": "Brian Westphal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianwestphal/domotion.git"
  },
  "homepage": "https://github.com/brianwestphal/domotion#readme",
  "bugs": {
    "url": "https://github.com/brianwestphal/domotion/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "domotion": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "src",
    "FEATURES.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:capture-script": "node scripts/build-capture-script.mjs",
    "build": "npm run build:capture-script && tsc",
    "typecheck": "npm run build:capture-script && tsc --noEmit",
    "lint": "eslint .",
    "capture": "npm run build:capture-script && tsx src/cli/index.ts",
    "test": "npm run build:capture-script && vitest run",
    "release": "bash scripts/release.sh",
    "release:beta": "bash scripts/release.sh --beta",
    "test:watch": "npm run build:capture-script && vitest",
    "test:linux-docker": "bash scripts/test-linux-docker.sh",
    "demos:test": "npm run build:capture-script && tsx tests/features.ts",
    "demos:test:showcase": "npm run build:capture-script && tsx tests/showcase.tsx",
    "demos:test:html": "npm run build:capture-script && tsx tests/html-test-suite.tsx",
    "demos:test:real-world": "npm run build:capture-script && tsx tests/real-world.tsx",
    "demos:test:snapshot-isolation": "npm run build:capture-script && tsx tests/snapshot-isolation.tsx",
    "demos:test:all": "npm run build:capture-script && (tsx tests/features.ts ; tsx tests/snapshot-isolation.tsx ; tsx tests/showcase.tsx ; tsx tests/html-test-suite.tsx ; tsx tests/real-world.tsx)",
    "demos:review": "tsx tests/review-server.tsx",
    "demos:examples": "npm run build:capture-script && tsx examples/terminal-demo.ts && tsx examples/showcase-rendering.ts && tsx examples/showcase-transitions.ts",
    "manual:images": "tsx site/scripts/generate-images.ts",
    "manual:build": "tsx site/build.ts",
    "manual:serve": "tsx site/serve.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "bidi-js": "^1.0.3",
    "fontkit": "^2.0.4",
    "kerfjs": "^0.13.0",
    "opentype.js": "^2.0.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "wawoff2": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.4",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-kerfjs": "^0.13.0",
    "happy-dom": "^20.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
